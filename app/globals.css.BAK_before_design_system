@tailwind base;
@tailwind components;
@tailwind utilities;

/* =========================
   Bidra Global Theme (MVP)
   Dark-mode first readability
   ========================= */

/* Brand + neutral tokens */
:root{
  /* Brand tokens (do not change logos/icons, only CSS colors) */
  --bidra-black: #0B0E11;
  --bidra-bg: #0B0E11;
  --bidra-card: #111720;
  --bidra-card2: #0F141B;

  --bidra-fg: #E6E8EB;
  --bidra-muted: #A7AFB7;
  --bidra-border: #243040;

  /* Brand blue */
  --bidra-blue: #1DA1F2;
  --bidra-link: #1DA1F2;

  /* Accents */
  --bidra-danger: #FF4D4F;
  --bidra-success: #22C55E;
}

@layer base {
  html, body { height: 100%; }

  body {
    background: var(--bidra-bg);
    color: var(--bidra-fg);
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Make default text readable everywhere */
  p, li, span, div, label, small {
    color: inherit;
  }

    /* Links: do NOT force global link color (it breaks buttons) */
  a { color: inherit; }
  a:hover { text-decoration: underline; }

/* Borders and separators */
  hr {
    border-color: var(--bidra-border);
  }

  /* Tables / outlines */
  table { color: var(--bidra-fg); }
}



header a, nav a {
  color: var(--bidra-fg);
}

header a:hover, nav a:hover {
  color: var(--bidra-link);
  text-decoration: underline;
}

/* If buttons in top-right are actually <button> elements */
header button, nav button {
  color: var(--bidra-fg);
}

/* If something is using "muted" text in the header */
header .muted, nav .muted {
  color: var(--bidra-muted);
}


/* =========================
   Bidra Base Layer (Modern)
   ========================= */
html, body {
  background: var(--bidra-bg);
  color: var(--bidra-fg);
}

body {
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Links */
a { color: var(--bidra-link); text-decoration-color: rgba(29,161,242,.35); }
a:hover { text-decoration: underline; }

/* Inputs - keep subtle, let Tailwind override when used */
/* Reduce “boxy lines everywhere” feeling */
hr { border-color: rgba(255,255,255,0.12); }