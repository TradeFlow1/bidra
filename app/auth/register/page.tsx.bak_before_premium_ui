"use client";

import { useMemo, useState } from "react";
import Link from "next/link";

type FormState = {
  email: string;
  password: string;
  username: string;
  dob: string;
  postcode: string;
  suburb: string;
  state: string;
};

export default function RegisterPage() {
  const [error, setError] = useState<string | null>(null);
  const [ok, setOk] = useState(false);
  const [loading, setLoading] = useState(false);

  const [form, setForm] = useState<FormState>({
    email: "",
    password: "",
    username: "",
    dob: "",
    postcode: "",
    suburb: "",
    state: "",
  });

  const hasPostcode = useMemo(() => form.postcode.trim().length > 0, [form.postcode]);
  const hasSuburbState = useMemo(
    () => form.suburb.trim().length > 0 || form.state.trim().length > 0,
    [form.suburb, form.state]
  );

  async function onSubmit(e: React.FormEvent<HTMLFormElement>) {
    e.preventDefault();
    setError(null);
    setLoading(true);

    const payload = {
      email: form.email.trim(),
      password: form.password,
      username: form.username.trim(),
      dob: form.dob.trim(),
      country: "AU",
      postcode: form.postcode.trim(),
      suburb: form.suburb.trim(),
      state: form.state.trim(),
    };

    const res = await fetch("/api/auth/register", {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify(payload),
    });

    const data = await res.json().catch(() => ({}));
    if (!res.ok) {
      setError(data?.error || "Registration failed");
      setLoading(false);
      return;
    }

    setOk(true);
    setLoading(false);
  }

  function onChange<K extends keyof FormState>(key: K, value: FormState[K]) {
    setForm((prev) => ({ ...prev, [key]: value }));
  }

  const fieldBase =
    "mt-1 w-full rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-white placeholder:text-white/40 outline-none focus:border-[var(--bidra-blue)] focus:ring-2 focus:ring-[var(--bidra-blue)]/30";
  const labelBase = "text-sm font-semibold text-white/90";
  const helperBase = "mt-1 text-xs text-white/50";

  return (
    <div className="min-h-[calc(100vh-64px)] bg-[var(--bidra-black)] px-4 py-10 text-white">
      <div className="mx-auto max-w-2xl">
        <div className="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-lg">
          <div className="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <h1 className="text-2xl font-extrabold tracking-tight">Create your Bidra account</h1>
              <p className="mt-2 text-sm text-white/70">
                Bidra accounts are <span className="font-semibold">18+</span>. Under 18s may browse but cannot create
                accounts.
              </p>
            </div>
            <div className="text-sm text-white/70">
              Already have an account?{" "}
              <Link className="font-semibold text-[var(--bidra-blue)] underline underline-offset-4" href="/auth/login">
                Log in
              </Link>
            </div>
          </div>

          {ok ? (
            <div className="mt-6 rounded-xl border border-white/10 bg-black/30 p-4">
              <p className="text-lg font-semibold">Account created ✅</p>
              <p className="mt-1 text-sm text-white/70">
                For MVP, your email verification link prints in the server console.
              </p>
              <Link
                className="mt-4 inline-block rounded-xl bg-[var(--bidra-blue)] px-4 py-2 font-semibold text-black"
                href="/auth/login"
              >
                Go to login
              </Link>
            </div>
          ) : (
            <form onSubmit={onSubmit} className="mt-6 space-y-6">
              {error ? (
                <div className="rounded-xl border border-red-400/40 bg-red-500/10 p-3 text-sm text-red-200">
                  {error}
                </div>
              ) : null}

              <div className="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div className="sm:col-span-2">
                  <label className={labelBase}>Email</label>
                  <input
                    value={form.email}
                    onChange={(e) => onChange("email", e.target.value)}
                    name="email"
                    type="email"
                    required
                    placeholder="you@example.com"
                    className={fieldBase}
                  />
                </div>

                <div>
                  <label className={labelBase}>Password</label>
                  <input
                    value={form.password}
                    onChange={(e) => onChange("password", e.target.value)}
                    name="password"
                    type="password"
                    required
                    minLength={8}
                    placeholder="Minimum 8 characters"
                    className={fieldBase}
                  />
                  <p className={helperBase}>Use 8+ characters. You can reset later.</p>
                </div>

                <div>
                  <label className={labelBase}>Username (unique)</label>
                  <input
                    value={form.username}
                    onChange={(e) => onChange("username", e.target.value)}
                    name="username"
                    required
                    minLength={3}
                    maxLength={24}
                    placeholder="e.g. hayden_markus"
                    className={fieldBase}
                  />
                  <p className={helperBase}>Letters, numbers, underscore, dot.</p>
                </div>

                <div>
                  <label className={labelBase}>Date of birth</label>
                  <input
                    value={form.dob}
                    onChange={(e) => onChange("dob", e.target.value)}
                    name="dob"
                    type="date"
                    required
                    className={fieldBase}
                  />
                  <p className={helperBase}>We use this to enforce 18+ only.</p>
                </div>

                <div className="sm:col-span-2">
                  <div className="rounded-2xl border border-white/10 bg-black/20 p-4">
                    <div className="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                      <p className="text-sm font-semibold text-white/90">Location (choose one)</p>
                      <p className="text-xs text-white/60">Country: AU (MVP)</p>
                    </div>

                    <div className="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
                      <div className="sm:col-span-1">
                        <label className={labelBase}>Postcode</label>
                        <input
                          value={form.postcode}
                          onChange={(e) => {
                            const v = e.target.value;
                            onChange("postcode", v);
                            if (v.trim().length > 0) {
                              // keep it clear for the user: postcode path wins
                              onChange("suburb", "");
                              onChange("state", "");
                            }
                          }}
                          name="postcode"
                          placeholder="4301"
                          className={fieldBase}
                          disabled={hasSuburbState}
                        />
                        <p className={helperBase}>
                          {hasSuburbState ? "Clear suburb/state to use postcode." : "Fastest option."}
                        </p>
                      </div>

                      <div className="hidden sm:block sm:col-span-1">
                        <div className="flex h-full items-center justify-center text-xs text-white/40">
                          — OR —
                        </div>
                      </div>

                      <div className="sm:col-span-1 sm:col-start-3">
                        <label className={labelBase}>Suburb</label>
                        <input
                          value={form.suburb}
                          onChange={(e) => {
                            const v = e.target.value;
                            onChange("suburb", v);
                            if (v.trim().length > 0) onChange("postcode", "");
                          }}
                          name="suburb"
                          placeholder="Redbank Plains"
                          className={fieldBase}
                          disabled={hasPostcode}
                        />

                        <label className={"mt-3 block " + labelBase}>State</label>
                        <input
                          value={form.state}
                          onChange={(e) => {
                            const v = e.target.value.toUpperCase();
                            onChange("state", v);
                            if (v.trim().length > 0) onChange("postcode", "");
                          }}
                          name="state"
                          placeholder="QLD"
                          className={fieldBase}
                          disabled={hasPostcode}
                        />
                        <p className={helperBase}>
                          {hasPostcode ? "Clear postcode to use suburb/state." : "Example: QLD, NSW, VIC"}
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <button
                disabled={loading}
                className="w-full rounded-xl bg-[var(--bidra-blue)] px-4 py-3 font-extrabold text-black disabled:opacity-60"
              >
                {loading ? "Creating account…" : "Create account"}
              </button>

              <p className="text-xs text-white/50">
                By creating an account you agree to Bidra’s Terms and confirm you are 18+.
              </p>
            </form>
          )}
        </div>
      </div>
    </div>
  );
}