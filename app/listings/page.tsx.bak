import { prisma } from "@/lib/prisma";
import Link from "next/link";

export default async function ListingsIndexPage() {
  const listings = await prisma.listing.findMany({
    orderBy: { createdAt: "desc" },
    take: 50,
    include: { seller: true },
  });

  return (
    <main className="mx-auto max-w-5xl p-6">
      <div className="flex items-center justify-between gap-4">
        <h1 className="text-3xl font-bold">Listings</h1>

        <Link
          href="/sell/new"
          className="rounded-md border px-3 py-2 text-sm font-medium"
        >
          Sell an item
        </Link>
      </div>

      <div className="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2">
        {listings.map((l) => (
          <Link
            key={l.id}
            href={`/listings/${l.id}`}
            className="rounded-lg border p-4 hover:opacity-90"
          >
            <div className="text-lg font-semibold">{l.title}</div>

            <div className="mt-1 text-sm opacity-80">
              ${Number(l.price || 0) / 100}
            </div>

            <div className="mt-2 text-xs opacity-70">
              Seller: {l.seller?.name || l.seller?.email || "Unknown"}
            </div>
          </Link>
        ))}
      </div>

      {listings.length === 0 ? (
        <p className="mt-6 text-sm opacity-70">No listings yet.</p>
      ) : null}
    </main>
  );
}