@tailwind base;
@tailwind components;
@tailwind utilities;

/* =========================
   Bidra Global Theme (MVP)
   Dark-mode first readability
   ========================= */

/* Brand + neutral tokens */
:root{
  --bidra-bg: #0B0E11;      /* brand black */
  --bidra-fg: #E6E8EB;      /* readable light text */
  --bidra-muted: #A7AFB7;   /* secondary text */
  --bidra-border: #243040;  /* subtle borders */
  --bidra-link: #1DA1F2;    /* brand blue */
  --bidra-card: #111720;    /* slightly lifted surface */
}

@layer base {
  html, body { height: 100%; }

  body {
    background: var(--bidra-bg);
    color: var(--bidra-fg);
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Make default text readable everywhere */
  p, li, span, div, label, small {
    color: inherit;
  }

    /* Links: do NOT force global link color (it breaks buttons) */
  a { color: inherit; }
  a:hover { text-decoration: underline; }/* Borders and separators */
  hr {
    border-color: var(--bidra-border);
  }

  /* Inputs: readable */
  input, textarea, select {
    background: var(--bidra-card);
    color: var(--bidra-fg);
    border: 1px solid var(--bidra-border);
  }
  input::placeholder, textarea::placeholder {
    color: var(--bidra-muted);
  }

  /* Tables / outlines */
  table { color: var(--bidra-fg); }
}

/* ===== Patch: Header / Top-right nav visibility ===== */
header, nav {
  color: var(--bidra-fg);
}

header a, nav a {
  color: var(--bidra-fg);
}

header a:hover, nav a:hover {
  color: var(--bidra-link);
  text-decoration: underline;
}

/* If buttons in top-right are actually <button> elements */
header button, nav button {
  color: var(--bidra-fg);
}

/* If something is using "muted" text in the header */
header .muted, nav .muted {
  color: var(--bidra-muted);
}


