@tailwind base;
@tailwind components;
@tailwind utilities;

/* =========================
   Bidra Design System (v1)
   - Clean, modern, trusted
   - Mobile-first marketplace UI
   - Dark + Light tokens
   ========================= */

/* ---------- Tokens ---------- */
:root {
  /* Brand */
  --brand-primary: #3B82F6;
  --brand-primary-soft: #DBEAFE;
  --brand-primary-dark: #1E40AF;

  /* Light mode */
  --bg-base: #F8FAFC;
  --bg-surface: #FFFFFF;
  --bg-elevated: #F1F5F9;

  --text-primary: #0F172A;
  --text-secondary: #475569;
  --text-muted: #64748B;

  --border-subtle: rgba(15, 23, 42, 0.12);

  /* Status */
  --success: #22C55E;
  --warning: #F59E0B;
  --error: #EF4444;

  /* Radius + shadow */
  --radius-sm: 10px;
  --radius-md: 14px;
  --radius-lg: 18px;

  --shadow-sm: 0 1px 2px rgba(2, 6, 23, 0.08);
  --shadow-md: 0 8px 24px rgba(2, 6, 23, 0.12);

  /* Spacing rhythm */
  --space-1: 4px;
  --space-2: 8px;
  --space-3: 12px;
  --space-4: 16px;
  --space-6: 24px;
  --space-8: 32px;
  --space-12: 48px;
}

/* Dark mode overrides (Tailwind uses .dark on <html>) */
.dark {
  --bg-base: #0B0E11;
  --bg-surface: #111720;
  --bg-elevated: #151C28;

  --text-primary: #E6E8EB;
  --text-secondary: #A7AFB7;
  --text-muted: #7C8796;

  --border-subtle: rgba(230, 232, 235, 0.14);
}

/* ---------- Base reset + readability ---------- */
html, body {
  height: 100%;
}

body {
  background: var(--bg-base);
  color: var(--text-primary);
  font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

/* Links */
a {
  color: var(--brand-primary);
  text-decoration: none;
}
a:hover {
  text-decoration: underline;
}

/* Remove the “boxed newspaper” feel */
* {
  box-sizing: border-box;
}

/* ---------- Layout containment (fixes full-width chaos) ---------- */
main {
  width: 100%;
  max-width: 1100px;
  margin: 0 auto;
  padding: 28px 18px;
}

/* Headings rhythm */
h1 { font-size: 2rem; line-height: 1.15; font-weight: 800; letter-spacing: -0.02em; }
h2 { font-size: 1.25rem; line-height: 1.2; font-weight: 700; }
p  { color: var(--text-secondary); }

/* ---------- Form styling (global MVP upgrade) ---------- */
form {
  display: grid;
  gap: 14px;
}

/* Labels */
label {
  display: block;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6px;
}

/* Inputs */
input, textarea, select {
  width: 100%;
  max-width: 640px;
  background: var(--bg-surface);
  color: var(--text-primary);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-sm);
  padding: 12px 14px;
  outline: none;
  box-shadow: var(--shadow-sm);
}

input::placeholder, textarea::placeholder {
  color: var(--text-muted);
}

/* Focus (trust + clarity) */
input:focus, textarea:focus, select:focus {
  border-color: rgba(59, 130, 246, 0.65);
  box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.22);
}

/* Button baseline (fixes ugly default button) */
button, input[type="submit"] {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;

  padding: 12px 16px;
  border-radius: var(--radius-sm);
  border: 1px solid transparent;

  background: var(--brand-primary);
  color: white;
  font-weight: 700;
  box-shadow: var(--shadow-md);
  cursor: pointer;

  transition: transform 120ms ease, background 120ms ease, box-shadow 120ms ease;
}

button:hover, input[type="submit"]:hover {
  background: var(--brand-primary-dark);
}

button:active, input[type="submit"]:active {
  transform: scale(0.985);
}

/* Secondary button option (when devs add class="btn-secondary") */
.btn-secondary {
  background: transparent !important;
  color: var(--brand-primary) !important;
  border-color: rgba(59, 130, 246, 0.35) !important;
  box-shadow: none !important;
}
.btn-secondary:hover {
  background: rgba(59, 130, 246, 0.10) !important;
}

/* ---------- Cards (when markup uses .card) ---------- */
.card {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  padding: 18px;
}

/* ---------- Simple “section divider” only ---------- */
hr {
  border: 0;
  border-top: 1px solid var(--border-subtle);
}