generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  offerDecisionsAsBuyer  OfferDecision[] @relation("OfferDecisionBuyer")
  offerDecisionsAsSeller OfferDecision[] @relation("OfferDecisionSeller")
  sellerThreads         MessageThread[]      @relation("SellerThreads")
  buyerThreads          MessageThread[]      @relation("BuyerThreads")
  id                    String               @id @default(cuid())
  email                 String               @unique
  passwordHash          String
  emailVerified         Boolean              @default(false)
  role                  Role                 @default(USER)
  name                  String?
  avatarUrl             String?
  location              String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  ageVerified           Boolean              @default(false)
  country               String?              @default("AU")
  dob                   DateTime?
  isActive              Boolean              @default(false)
  phone                 String?
  phoneVerified         Boolean              @default(false)
  postcode              String?
  state                 String?
  suburb                String?
  username              String?              @unique
  termsAcceptedAt       DateTime?
  termsVersion          String?
  policyBlockedUntil    DateTime?
  policyStrikes         Int                  @default(0)
  badgeConsistentSeller Boolean              @default(false)
  badgeFastResponder    Boolean              @default(false)
  badgeNewSeller        Boolean              @default(false)
  bio                   String?
  activitySessions      ActivitySession[]
  adminActionLogs       AdminActionLog[]
  bids                  Bid[]
  offerMaxes OfferMax[]
  feedbackGiven         Feedback[]           @relation("FeedbackFrom")
  feedbackReceived      Feedback[]           @relation("FeedbackTo")
  listings              Listing[]            @relation("SellerListings")
  listingAnswers        ListingAnswer[]
  listingQuestions      ListingQuestion[]
  messages              Message[]
  orders                Order[]              @relation("BuyerOrders")
  passwordResetTokens   PasswordResetToken[]
  clearedStrikes        PolicyStrike[]       @relation("ClearedStrikes")
  policyStrikeEvents    PolicyStrike[]       @relation("UserPolicyStrikes")
  reports               Report[]             @relation("ReporterReports")
  verificationTokens    VerificationToken[]
  watchlist             Watchlist[]
  // Payout details (Osko/PayID + bank). Optional; shown on /orders/[id]/pay
  payidEmail   String?
  payidMobile  String?
  bankName     String?
  bankBsb      String?
  bankAccount  String?
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Listing {
  offerDecisions OfferDecision[]
  photos String[] @default([])
  threads        MessageThread[]
  id             String            @id @default(cuid())
  title          String
  description    String
  category       String
  type           ListingType
  status         ListingStatus     @default(DRAFT)
  condition      String
  price          Int
  images         String[]
  location       String
  endsAt         DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  sellerId       String
  buyNowPrice    Int?
  buyNowEnabled Boolean @default(false)
  reservePrice   Int?
  previousStatus ListingStatus?
  bids           Bid[]
  offerMaxes OfferMax[]
  seller         User              @relation("SellerListings", fields: [sellerId], references: [id])
  questions      ListingQuestion[]
  messages       Message[]
  orders         Order[]
  policyStrikes  PolicyStrike[]
  reports        Report[]
  watchlist      Watchlist[]
  pickupAvailability Json?
  pickupTimezone     String @default("Australia/Brisbane")
}

model Bid {
  offerDecision OfferDecision?
  id        String   @id @default(cuid())
  amount    Int
  createdAt DateTime @default(now())
  bidderId  String
  listingId String
  bidder    User     @relation(fields: [bidderId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])

  @@index([listingId])
  @@index([bidderId])
}

model MessageThread {
  id            String   @id @default(cuid())
  listingId     String
  buyerId       String
  sellerId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime @default(now())
  buyerLastReadAt      DateTime?
sellerLastReadAt     DateTime?
  buyerDeletedAt      DateTime?
  sellerDeletedAt     DateTime?

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    User      @relation("BuyerThreads", fields: [buyerId], references: [id])
  seller   User      @relation("SellerThreads", fields: [sellerId], references: [id])
  messages Message[]

  @@unique([listingId, buyerId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
}

model Message {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())
  userId    String
  listingId String
  threadId  String?

  listing Listing        @relation(fields: [listingId], references: [id])
  user    User           @relation(fields: [userId], references: [id])
  thread  MessageThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([userId])
  @@index([threadId])
}

model Watchlist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, listingId])
  @@index([listingId])
}

model Report {
  id            String         @id @default(cuid())
  reason        String
  details       String?
  resolved      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  reporterId    String
  listingId     String
  policyStrikes PolicyStrike[]
  listing       Listing        @relation(fields: [listingId], references: [id])
  reporter      User           @relation("ReporterReports", fields: [reporterId], references: [id])

  @@index([listingId])
  @@index([reporterId])
}

model Order {
  offerDecision OfferDecision?
  id               String      @id @default(cuid())
  amount           Int
  status           OrderStatus @default(PENDING)
  stripeSessionId  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  buyerId          String
  listingId        String
  outcome          SaleOutcome @default(PENDING)
  buyerFeedbackAt  DateTime?
  sellerFeedbackAt DateTime?
  completedAt      DateTime?
  feedback         Feedback[]
  buyer            User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  listing          Listing     @relation(fields: [listingId], references: [id])

  @@index([buyerId])
  @@index([listingId])
  pickupScheduledAt       DateTime?
  pickupScheduleLockedAt  DateTime?
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

model Feedback {
  id         String       @id @default(cuid())
  role       FeedbackRole
  rating     Int
  comment    String?
  createdAt  DateTime     @default(now())
  orderId    String
  fromUserId String
  toUserId   String
  fromUser   User         @relation("FeedbackFrom", fields: [fromUserId], references: [id])
  order      Order        @relation(fields: [orderId], references: [id])
  toUser     User         @relation("FeedbackTo", fields: [toUserId], references: [id])

  @@unique([orderId, fromUserId])
  @@index([orderId])
  @@index([fromUserId])
  @@index([toUserId])
}

model PolicyStrike {
  id            String             @id @default(cuid())
  action        PolicyStrikeAction @default(WARN)
  reason        String
  createdAt     DateTime           @default(now())
  expiresAt     DateTime
  clearedAt     DateTime?
  clearedReason String?
  userId        String
  clearedById   String?
  reportId      String?
  listingId     String?
  clearedBy     User?              @relation("ClearedStrikes", fields: [clearedById], references: [id])
  listing       Listing?           @relation(fields: [listingId], references: [id])
  report        Report?            @relation(fields: [reportId], references: [id])
  user          User               @relation("UserPolicyStrikes", fields: [userId], references: [id])

  @@index([userId])
  @@index([reportId])
  @@index([listingId])
  @@index([expiresAt])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  adminId    String
  action     String
  entityType String
  entityId   String?
  reportId   String?
  listingId  String?
  userId     String?
  meta       Json?
  admin      User     @relation(fields: [adminId], references: [id])
}

model ActivitySession {
  id            String   @id @default(cuid())
  sessionId     String   @unique
  userId        String?
  startedAt     DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  totalActiveMs Int      @default(0)
  totalIdleMs   Int      @default(0)
  lastPath      String?
  lastReferrer  String?
  userAgent     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([lastSeenAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ListingQuestion {
  id        String          @id @default(cuid())
  listingId String
  userId    String
  text      String
  createdAt DateTime        @default(now())
  deletedAt DateTime?
  answers   ListingAnswer[]
  listing   Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([userId])
}

model ListingAnswer {
  id         String          @id @default(cuid())
  questionId String
  userId     String
  text       String
  createdAt  DateTime        @default(now())
  deletedAt  DateTime?
  question   ListingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
}

enum Role {
  USER
  ADMIN
}

enum ListingType {
  AUCTION
  BUY_NOW
  FIXED_PRICE
}

enum ListingStatus {
  DRAFT
  ACTIVE
  ENDED
  SOLD
  SUSPENDED
  DELETED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  PICKUP_REQUIRED
  PICKUP_SCHEDULED
}

enum FeedbackRole {
  BUYER
  SELLER
}

enum SaleOutcome {
  PENDING
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PolicyStrikeAction {
  WARN
}
model AdminEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // e.g. "FEEDBACK_SUBMITTED_WHILE_BLOCKED"
  type      String

  // actor user id
  userId    String?

  // useful linkage (optional)
  orderId   String?

  // structured payload
  data      Json?
}


model OfferMax {
  id        String   @id @default(cuid())
  listingId String
  bidderId  String
  maxAmount Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bidder  User    @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  @@unique([listingId, bidderId])
  @@index([listingId])
  @@index([bidderId])
}


enum OfferDecisionKind {
  ACCEPTED
  REJECTED
}

model OfferDecision {
  id        String            @id @default(cuid())
  createdAt DateTime          @default(now())

  listingId String
  bidId     String @unique

  sellerId  String
  buyerId   String

  amount    Int
  decision  OfferDecisionKind

  orderId   String? @unique

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bid     Bid     @relation(fields: [bidId], references: [id], onDelete: Cascade)

  seller  User   @relation("OfferDecisionSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  buyer   User   @relation("OfferDecisionBuyer", fields: [buyerId], references: [id], onDelete: Cascade)

  order   Order? @relation(fields: [orderId], references: [id])

  @@unique([listingId, bidId])
  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([decision])
}

