generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  policyStrikes          Int                  @default(0)
  policyBlockedUntil     DateTime?
  termsAcceptedAt        DateTime?
  termsVersion           String?
  id                     String               @id @default(cuid())
  email                  String               @unique
  username               String?              @unique
  dob                    DateTime?
  country                String?              @default("AU")
  state                  String?
  suburb                 String?
  postcode               String?
  phone                  String?
  phoneVerified          Boolean              @default(false)
  ageVerified            Boolean              @default(false)
  isActive               Boolean              @default(false)
  passwordHash           String
  emailVerified          Boolean              @default(false)
  role                   Role                 @default(USER)
  name                   String?
  avatarUrl              String?
  location               String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  badgeConsistentSeller  Boolean              @default(false)
  badgeFastResponder     Boolean              @default(false)
  badgeNewSeller         Boolean              @default(false)
  bankAccount            String?
  bankBsb                String?
  bankName               String?
  bio                    String?
  payidEmail             String?
  payidMobile            String?
  activitySessions       ActivitySession[]
  adminActionLogs        AdminActionLog[]
  offers                 Offer[]
  feedbackGiven          Feedback[]           @relation("FeedbackFrom")
  feedbackReceived       Feedback[]           @relation("FeedbackTo")
  listings               Listing[]            @relation("SellerListings")
  listingAnswers         ListingAnswer[]
  listingQuestions       ListingQuestion[]
  messages               Message[]
  buyerThreads           MessageThread[]      @relation("BuyerThreads")
  sellerThreads          MessageThread[]      @relation("SellerThreads")
  offerDecisionsAsBuyer  OfferDecision[]      @relation("OfferDecisionBuyer")
  offerDecisionsAsSeller OfferDecision[]      @relation("OfferDecisionSeller")
  offerMaxes             OfferMax[]
  orders                 Order[]              @relation("BuyerOrders")
  passwordResetTokens    PasswordResetToken[]
  clearedStrikes         PolicyStrike[]       @relation("ClearedStrikes")
  policyStrikeEvents     PolicyStrike[]       @relation("UserPolicyStrikes")
  reports                Report[]             @relation("ReporterReports")
  verificationTokens     VerificationToken[]
  watchlist              Watchlist[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Listing {
  reservePrice       Int?
  buyNowPrice        Int?
  id                 String            @id @default(cuid())
  title              String
  description        String
  category           String
  type               ListingType
  status             ListingStatus     @default(DRAFT)
  condition          String
  price              Int
  images             String[]
  location           String
  endsAt             DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  sellerId           String
  buyNowEnabled      Boolean           @default(false)
  photos             String[]          @default([])
  previousStatus     ListingStatus?
  pickupAvailability Json?
  pickupTimezone     String            @default("Australia/Brisbane")
  offers             Offer[]
  seller             User              @relation("SellerListings", fields: [sellerId], references: [id])
  questions          ListingQuestion[]
  messages           Message[]
  threads            MessageThread[]
  offerDecisions     OfferDecision[]
  offerMaxes         OfferMax[]
  orders             Order[]
  policyStrikes      PolicyStrike[]
  reports            Report[]
  watchlist          Watchlist[]
}

model Offer {
  id            String         @id @default(cuid())
  amount        Int
  createdAt     DateTime       @default(now())
  bidderId      String
  listingId     String
  expiresAt     DateTime
  bidder        User           @relation(fields: [bidderId], references: [id])
  listing       Listing        @relation(fields: [listingId], references: [id])
  offerDecision OfferDecision?

  @@index([listingId])
  @@index([bidderId])
  @@map("Bid")
}

model MessageThread {
  id               String    @id @default(cuid())
  listingId        String
  buyerId          String
  sellerId         String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastMessageAt    DateTime  @default(now())
  buyerLastReadAt  DateTime?
  sellerLastReadAt DateTime?
  buyerDeletedAt   DateTime?
  sellerDeletedAt  DateTime?
  messages         Message[]
  buyer            User      @relation("BuyerThreads", fields: [buyerId], references: [id])
  listing          Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  seller           User      @relation("SellerThreads", fields: [sellerId], references: [id])

  @@unique([listingId, buyerId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
}

model Message {
  id        String         @id @default(cuid())
  body      String
  createdAt DateTime       @default(now())
  userId    String
  listingId String
  threadId  String?
  listing   Listing        @relation(fields: [listingId], references: [id])
  thread    MessageThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id])

  @@index([listingId])
  @@index([userId])
  @@index([threadId])
}

model Watchlist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, listingId])
  @@index([listingId])
}

model Report {
  id            String         @id @default(cuid())
  reason        String
  details       String?
  resolved      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  reporterId    String
  listingId     String
  policyStrikes PolicyStrike[]
  listing       Listing        @relation(fields: [listingId], references: [id])
  reporter      User           @relation("ReporterReports", fields: [reporterId], references: [id])

  @@index([listingId])
  @@index([reporterId])
}

model Order {
  id                     String         @id @default(cuid())
  amount                 Int
  status                 OrderStatus    @default(PENDING)
  stripeSessionId        String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  buyerId                String
  listingId              String
  outcome                SaleOutcome    @default(PENDING)
  buyerFeedbackAt        DateTime?
  sellerFeedbackAt       DateTime?
  completedAt            DateTime?
  pickupScheduleLockedAt DateTime?
  pickupScheduledAt      DateTime?
  feedback               Feedback[]
  offerDecision          OfferDecision?
  buyer                  User           @relation("BuyerOrders", fields: [buyerId], references: [id])
  listing                Listing        @relation(fields: [listingId], references: [id])

  @@index([buyerId])
  @@index([listingId])
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

model Feedback {
  id         String       @id @default(cuid())
  role       FeedbackRole
  rating     Int
  comment    String?
  createdAt  DateTime     @default(now())
  orderId    String
  fromUserId String
  toUserId   String
  fromUser   User         @relation("FeedbackFrom", fields: [fromUserId], references: [id])
  order      Order        @relation(fields: [orderId], references: [id])
  toUser     User         @relation("FeedbackTo", fields: [toUserId], references: [id])

  @@unique([orderId, fromUserId])
  @@index([orderId])
  @@index([fromUserId])
  @@index([toUserId])
}

model PolicyStrike {
  id            String             @id @default(cuid())
  action        PolicyStrikeAction @default(WARN)
  reason        String
  createdAt     DateTime           @default(now())
  expiresAt     DateTime
  clearedAt     DateTime?
  clearedReason String?
  userId        String
  clearedById   String?
  reportId      String?
  listingId     String?
  clearedBy     User?              @relation("ClearedStrikes", fields: [clearedById], references: [id])
  listing       Listing?           @relation(fields: [listingId], references: [id])
  report        Report?            @relation(fields: [reportId], references: [id])
  user          User               @relation("UserPolicyStrikes", fields: [userId], references: [id])

  @@index([userId])
  @@index([reportId])
  @@index([listingId])
  @@index([expiresAt])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  adminId    String
  action     String
  entityType String
  entityId   String?
  reportId   String?
  listingId  String?
  userId     String?
  meta       Json?
  admin      User     @relation(fields: [adminId], references: [id])
}

model ActivitySession {
  id            String   @id @default(cuid())
  sessionId     String   @unique
  userId        String?
  startedAt     DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  totalActiveMs Int      @default(0)
  totalIdleMs   Int      @default(0)
  lastPath      String?
  lastReferrer  String?
  userAgent     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([lastSeenAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ListingQuestion {
  id        String          @id @default(cuid())
  listingId String
  userId    String
  text      String
  createdAt DateTime        @default(now())
  deletedAt DateTime?
  answers   ListingAnswer[]
  listing   Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([userId])
}

model ListingAnswer {
  id         String          @id @default(cuid())
  questionId String
  userId     String
  text       String
  createdAt  DateTime        @default(now())
  deletedAt  DateTime?
  question   ListingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
}

model AdminEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  type      String
  userId    String?
  orderId   String?
  data      Json?
}

model OfferMax {
  id        String   @id @default(cuid())
  listingId String
  bidderId  String
  maxAmount Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
  bidder    User     @relation(fields: [bidderId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, bidderId])
  @@index([listingId])
  @@index([bidderId])
  @@index([expiresAt])
}

model OfferDecision {
  id        String            @id @default(cuid())
  createdAt DateTime          @default(now())
  listingId String
  offerId   String            @unique @map("bidId")
  sellerId  String
  buyerId   String
  amount    Int
  decision  OfferDecisionKind
  orderId   String?           @unique
  Offer     Offer             @relation(fields: [offerId], references: [id], onDelete: Cascade)
  buyer     User              @relation("OfferDecisionBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  listing   Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  order     Order?            @relation(fields: [orderId], references: [id])
  seller    User              @relation("OfferDecisionSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([listingId, offerId])
  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([decision])
}

enum Role {
  USER
  ADMIN
}

enum ListingType {
  AUCTION
  BUY_NOW
  FIXED_PRICE
}

enum ListingStatus {
  DRAFT
  ACTIVE
  ENDED
  SOLD
  SUSPENDED
  DELETED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  PICKUP_REQUIRED
  PICKUP_SCHEDULED
}

enum FeedbackRole {
  BUYER
  SELLER
}

enum SaleOutcome {
  PENDING
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PolicyStrikeAction {
  WARN
}

enum OfferDecisionKind {
  ACCEPTED
  REJECTED
}
