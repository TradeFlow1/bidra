generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  policyStrikeEvents PolicyStrike[] @relation("UserPolicyStrikes")
  clearedStrikes     PolicyStrike[] @relation("ClearedStrikes")
  policyStrikes      Int            @default(0)
  policyBlockedUntil DateTime?

  termsAcceptedAt DateTime?
  termsVersion    String?

  id                 String              @id @default(cuid())
  email              String              @unique
  username           String?             @unique
  dob                DateTime?
  country            String?             @default("AU")
  state              String?
  suburb             String?
  postcode           String?
  phone              String?
  phoneVerified      Boolean             @default(false)
  ageVerified        Boolean             @default(false)
  isActive           Boolean             @default(false)
  passwordHash       String
  emailVerified      Boolean             @default(false)
  role               Role                @default(USER)
  name               String?
  avatarUrl          String?
  location           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  bids               Bid[]
  listings           Listing[]           @relation("SellerListings")
  messages           Message[]
  orders             Order[]             @relation("BuyerOrders")
  reports            Report[]            @relation("ReporterReports")
  verificationTokens VerificationToken[]
  watchlist          Watchlist[]
  feedbackGiven      Feedback[]          @relation("FeedbackFrom")
  feedbackReceived   Feedback[]          @relation("FeedbackTo")
  adminActionLogs    AdminActionLog[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Listing {
  policyStrikes PolicyStrike[]
  reservePrice  Int?
  buyNowPrice   Int?

  id             String         @id @default(cuid())
  title          String
  description    String
  category       String
  type           ListingType
  status         ListingStatus  @default(DRAFT)
  previousStatus ListingStatus?
  condition      String
  price          Int
  images         String[]
  location       String
  endsAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  sellerId       String
  bids           Bid[]
  seller         User           @relation("SellerListings", fields: [sellerId], references: [id])
  messages       Message[]
  orders         Order[]
  reports        Report[]
  watchlist      Watchlist[]
}

model Bid {
  id        String   @id @default(cuid())
  amount    Int
  createdAt DateTime @default(now())
  bidderId  String
  listingId String
  bidder    User     @relation(fields: [bidderId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])

  @@index([listingId])
  @@index([bidderId])
}

model Message {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())
  userId    String
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([listingId])
  @@index([userId])
}

model Watchlist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, listingId])
  @@index([listingId])
}

model Report {
  policyStrikes PolicyStrike[]
  id            String         @id @default(cuid())
  reason        String
  details       String?
  resolved      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  reporterId    String
  listingId     String
  listing       Listing        @relation(fields: [listingId], references: [id])
  reporter      User           @relation("ReporterReports", fields: [reporterId], references: [id])

  @@index([listingId])
  @@index([reporterId])
}

model Order {
  id               String      @id @default(cuid())
  amount           Int
  status           OrderStatus @default(PENDING)
  stripeSessionId  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  buyerId          String
  listingId        String
  buyer            User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  listing          Listing     @relation(fields: [listingId], references: [id])
  outcome          SaleOutcome @default(PENDING)
  buyerFeedbackAt  DateTime?
  sellerFeedbackAt DateTime?
  completedAt      DateTime?
  feedback         Feedback[]

  @@index([buyerId])
  @@index([listingId])
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum Role {
  USER
  ADMIN
}

enum ListingType {
  AUCTION
  BUY_NOW
  FIXED_PRICE
}

enum ListingStatus {
  DRAFT
  ACTIVE
  ENDED
  SOLD
  SUSPENDED
  DELETED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

model Feedback {
  id        String       @id @default(cuid())
  role      FeedbackRole
  rating    Int
  comment   String?
  createdAt DateTime     @default(now())

  orderId    String
  fromUserId String
  toUserId   String

  order    Order @relation(fields: [orderId], references: [id])
  fromUser User  @relation("FeedbackFrom", fields: [fromUserId], references: [id])
  toUser   User  @relation("FeedbackTo", fields: [toUserId], references: [id])

  @@unique([orderId, fromUserId])
  @@index([orderId])
  @@index([fromUserId])
  @@index([toUserId])
}

enum FeedbackRole {
  BUYER
  SELLER
}

enum SaleOutcome {
  PENDING
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PolicyStrikeAction {
  WARN
}

model PolicyStrike {
  id String @id @default(cuid())

  action PolicyStrikeAction @default(WARN)
  reason String

  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  clearedAt     DateTime?
  clearedReason String?

  userId String
  user   User   @relation("UserPolicyStrikes", fields: [userId], references: [id])

  clearedById String?
  clearedBy   User?   @relation("ClearedStrikes", fields: [clearedById], references: [id])

  reportId String?
  report   Report? @relation(fields: [reportId], references: [id])

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id])

  @@index([userId])
  @@index([reportId])
  @@index([listingId])
  @@index([expiresAt])
}

model AdminActionLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  adminId String
  admin   User   @relation(fields: [adminId], references: [id])

  action     String
  entityType String
  entityId   String?

  reportId  String?
  listingId String?
  userId    String?

  meta Json?
}
