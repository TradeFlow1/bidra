import prisma from "@/lib/prisma";

export async function getPendingFeedbackCount(userId: string) {
  // Pending if:
  // - user is buyer and buyerFeedbackAt is null
  // - OR user is the seller (via listing.sellerId) and sellerFeedbackAt is null
  // - AND the order is in a state that requires feedback (COMPLETED)
  //
  // If your enum is named differently, we’ll adjust after the next step output.
  const pending = await prisma.order.count({
    where: {
      outcome: "COMPLETED",
      OR: [
        { buyerId: userId, buyerFeedbackAt: null },
        { listing: { sellerId: userId }, sellerFeedbackAt: null },
      ],
    },
  });

  return pending;
}